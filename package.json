{
  "name": "focus-board",
  "version": "0.1.0",
  "description": "A frictionless Kanban interface for executive task management, delegation tracking, and performance record-keeping.",
  "private": true,
  "main": "src/server/index.js",
  "scripts": {
    "start": "node --env-file .env.production src/server/index.js",
    "dev": "concurrently --names server,client --prefix-colors blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch src/server --watch src/db --exec 'node --env-file .env' src/server/index.js",
    "dev:client": "cd src/client && npx vite",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint src/ tests/",
    "db:migrate": "node src/db/migrate.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^4.21.0",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

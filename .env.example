# galloway-os — Environment Variables Template
# Copy to .env for local development, .env.production for Docker.
# NEVER commit .env or .env.production to version control.

# --- Server Configuration ---
# Port the Express backend API listens on locally
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# --- Database ---
# The filename of the SQLite database to boot natively mapping into src/db
DB_FILE=dev.sqlite

# --- Logging ---
# Log level (error | warn | info | debug)
LOG_LEVEL=info

# --- Recurring Task Scheduler ---
# IANA timezone for cron evaluation (e.g., America/Chicago, America/New_York)
TZ=America/Chicago

# Cron expression controlling when recurring tasks are evaluated (default: 5:00 AM daily)
# Format: minute hour day-of-month month day-of-week
RECURRING_CRON=0 5 * * *

# galloway-os — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.

# --- Server Configuration ---
# Port the Express backend API listens on
PORT=7432

# Port the Vite frontend dev server listens on (dev mode only)
VITE_PORT=7433

# Node environment (development | production)
NODE_ENV=development

# --- Database ---
# Path to the SQLite database file (relative to working directory inside container)
DATABASE_PATH=./data/galloway-os.sqlite

# --- Logging ---
# Log level (error | warn | info | debug)
LOG_LEVEL=info
